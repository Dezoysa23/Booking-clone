# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — allow .env.example as a committed template
.env*
!.env.example

# User-uploaded content
/public/uploads/

# Claude Code local settings (user-specific permissions, not shared)
.claude/settings.local.json

# Claude Code plugin runtime state
.impeccable/

# Unrelated files
network_topology
network_topology.gv
network_topology.py
unzip.bat

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
