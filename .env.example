# ------------------------------------------------------------------
# Pearlora — environment variables (PLACEHOLDERS ONLY; never commit real values)
# Copy this file to .env and fill in real values. .env is gitignored.
# ------------------------------------------------------------------

# --- Database (Neon PostgreSQL) ---
# Pooled connection — used by the app at runtime (via @prisma/adapter-neon).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection — used by Prisma migrations only.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth ---
# HMAC signing secret for session cookies. REQUIRED in production.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Pearlora <noreply@yourdomain.com>"

# --- Public base URL (used in email links; safe to expose to the browser) ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Cron: booking reminders ---
# The scheduler must send this as:  Authorization: Bearer <CRON_SECRET>
# (Vercel Cron does this automatically once CRON_SECRET is set.)
CRON_SECRET="change-me-to-a-long-random-string"

# --- Payment webhook (mock provider for now) ---
# Callers must send this exact value in the `x-webhook-signature` header.
# When a real provider (Stripe/PayHere) is wired, replace this with the
# provider's endpoint signing secret and verify a real HMAC signature.
PAYMENT_WEBHOOK_SECRET="change-me-to-a-long-random-string"

# --- Rate limiting (Upstash Redis) ---
# When BOTH are set, rate limiting uses Upstash (production-grade, coordinated
# across serverless instances). When unset, an in-memory fallback runs —
# DEV ONLY, not safe for production.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- CORS / allowed origins (comma-separated) ---
# Defaults to same-origin only (enforced via Origin/Referer CSRF checks).
# Set this when you add a custom domain, e.g.:
#   ALLOWED_ORIGINS="https://your-app.vercel.app,https://gopearlora.com,http://localhost:3000"
ALLOWED_ORIGINS=""
