# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooled connection — used at runtime by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true"

# Direct connection — used by Prisma CLI for migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── Session ──────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret — must be a long, random, unique string in production.
# Generate with: openssl rand -hex 64
SESSION_SECRET="replace-with-a-long-random-secret"

# ─── Email ────────────────────────────────────────────────────────────────────
# Option A: Gmail SMTP (recommended for low volume)
# Use a 16-character App Password (not your account password).
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER="youraddress@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Option B: Resend (recommended for production)
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Pearlora <noreply@yourdomain.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
# Full public URL of the app — used in email links and CSRF origin checks
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Protects /api/cron/booking-reminders — REQUIRED in production.
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-with-a-random-secret"
